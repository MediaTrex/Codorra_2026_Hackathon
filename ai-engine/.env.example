# Environment variables for AI Engine

# Backend API Configuration
BACKEND_API_URL=http://localhost:8000
BACKEND_API_KEY=

# Video Processing
FRAME_SKIP=5
FRAME_WIDTH=640
FRAME_HEIGHT=480

# YOLO Configuration
YOLO_MODEL=yolov8m.pt
YOLO_CONFIDENCE=0.5
YOLO_IOU=0.45

# Density Estimation
DEFAULT_CAPACITY=100
DENSITY_LOW_THRESHOLD=30
DENSITY_MEDIUM_THRESHOLD=60
DENSITY_HIGH_THRESHOLD=85

# Face Blurring
BLUR_KERNEL_SIZE=31
ENABLE_FACE_BLUR=true

# Processing
MAX_WORKERS=4
BATCH_SIZE=10

# Logging
LOG_LEVEL=INFO
LOG_FILE=ai_engine.log
